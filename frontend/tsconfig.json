/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "paths": {
      "api": ["./dist/api"],
      "components": ["./dist/components"],
      "feature-auth": ["./dist/feature-auth"],
      "feature-contacts": ["./dist/feature-contacts"],
      "feature-dashboard": ["./dist/feature-dashboard"],
      "feature-partners": ["./dist/feature-partners"],
      "feature-hackathons": ["./dist/feature-hackathons"],
      "feature-team": ["./dist/feature-team"]
    },
    "strict": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./projects/components/tsconfig.lib.json"
    },
    {
      "path": "./projects/components/tsconfig.spec.json"
    },
    {
      "path": "./projects/api/tsconfig.lib.json"
    },
    {
      "path": "./projects/api/tsconfig.spec.json"
    },
    {
      "path": "./projects/app-shell/tsconfig.app.json"
    },
    {
      "path": "./projects/app-shell/tsconfig.spec.json"
    },
    {
      "path": "./projects/feature-auth/tsconfig.lib.json"
    },
    {
      "path": "./projects/feature-auth/tsconfig.spec.json"
    },
    {
      "path": "./projects/feature-contacts/tsconfig.lib.json"
    },
    {
      "path": "./projects/feature-contacts/tsconfig.spec.json"
    },
    {
      "path": "./projects/feature-partners/tsconfig.lib.json"
    },
    {
      "path": "./projects/feature-partners/tsconfig.spec.json"
    },
    {
      "path": "./projects/feature-hackathons/tsconfig.lib.json"
    },
    {
      "path": "./projects/feature-hackathons/tsconfig.spec.json"
    },
    {
      "path": "./projects/feature-team/tsconfig.lib.json"
    },
    {
      "path": "./projects/feature-team/tsconfig.spec.json"
    },
    {
      "path": "./projects/feature-dashboard/tsconfig.lib.json"
    },
    {
      "path": "./projects/feature-dashboard/tsconfig.spec.json"
    }
  ]
}
