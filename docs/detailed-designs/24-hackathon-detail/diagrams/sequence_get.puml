@startuml sequence_get
!theme plain
title View Hackathon Detail

actor User
participant "HackathonDetail" as P
participant "HackathonsController" as C
participant "Handler" as H
database "DB" as DB

User -> P: open /hackathons/{id}
P -> C: GET /api/hackathons/{id}
C -> DB: resolve Hackathon.TeamId
alt non-admin and other team
  C --> P: 404
else allowed
  C -> H: GetHackathonQuery{TargetTeamId}
  H -> DB: SELECT dates + city + current stage + Partners + Products(+Members) + History
  H --> C: HackathonDto
  C --> P: 200
  P --> User: render sections
end
@enduml
